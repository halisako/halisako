# Base URL used for canonical links and absolute Open Graph image URLs.
# Set this to your production domain in Vercel's Project Settings → Environment Variables.
# Falls back to lib/site-config.ts's siteConfig.url if unset.
NEXT_PUBLIC_SITE_URL=https://halisako.com

# Base URL of the real Chess2Fight FastAPI backend (see /backend),
# e.g. https://halisako-chess2fight-api.onrender.com — no trailing
# slash. Leave unset to keep using mock generation data.
# CHESS2FIGHT_API_URL=
